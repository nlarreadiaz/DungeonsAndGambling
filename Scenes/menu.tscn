[sub_resource type="GDScript" id="GDScript_158mb"]
script/source = "extends Label

# Guardamos la posición original
@onready var y_inicial = position.y

func _ready():
	var boton = get_parent()
	
	if boton is TextureButton:
		# Conectamos todas las señales necesarias
		boton.mouse_entered.connect(_al_entrar)
		boton.mouse_exited.connect(_al_salir)
		boton.button_down.connect(_al_presionar)
		boton.button_up.connect(_al_entrar) # Al soltar, vuelve al estado 'hover'

func _al_entrar():
	# Estado HOVER: baja 1 píxel
	position.y = y_inicial + 1

func _al_salir():
	# Estado NORMAL: vuelve a la posición original
	position.y = y_inicial

func _al_presionar():
	# Estado CLICK: baja 2 píxeles
	position.y = y_inicial + 2
"

